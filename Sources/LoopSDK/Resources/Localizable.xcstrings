    "Hit something odd, or got an idea? Be the first to log it — the team gets it instantly." : {
      "comment" : "Empty-state body copy under the heading.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "هل لاحظت شيئًا غريبًا، أو لديك فكرة؟ كن أوّل من يسجّلها — الفريق يتلقّاها فورًا." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Etwas Komisches entdeckt oder eine Idee? Sei der Erste, der es meldet — das Team bekommt's sofort." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hit something odd, or got an idea? Be the first to log it — the team gets it instantly." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "¿Has visto algo raro o tienes una idea? Sé el primero en registrarlo — el equipo lo recibe al instante." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "¿Viste algo raro o tienes una idea? Sé el primero en reportarlo — el equipo lo recibe al instante." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu as vu un truc bizarre, ou tu as une idée ? Sois le premier à le signaler — l'équipe le reçoit aussitôt." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "कुछ अजीब दिखा, या कोई आइडिया है? सबसे पहले बताइए — टीम को तुरंत मिलेगा।" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Hai notato qualcosa di strano, o hai un'idea? Sii il primo a segnalarlo — il team la riceve subito." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "おかしな点を見つけたり、アイデアがあったりしますか？最初に投稿してください — チームにすぐ届きます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "이상한 걸 발견했거나 아이디어가 있나요? 가장 먼저 등록해 보세요 — 팀이 바로 받습니다." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Iets vreemds gezien, of een idee? Wees de eerste die het meldt — het team krijgt het direct." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Viu algo estranho ou tem uma ideia? Seja o primeiro a relatar — a equipe recebe na hora." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Заметили что-то странное или есть идея? Сообщите первым — команда увидит сразу." } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Tuhaf bir şey gördün ya da bir fikrin mi var? İlk sen bildir — ekip anında alır." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "发现了奇怪的地方，或者有什么想法？第一个反馈吧 — 团队会立即收到。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "發現了奇怪的地方，或有想法？第一個回報吧 — 團隊馬上就會看到。" } }
      }
    },
