    "We attach `device`, `os`, `app version` and a session id automatically. No personal info is sent." : {
      "comment" : "Privacy disclosure under the compose form. Backticks render as inline monospace runs (preserve them around the device/os/app-version keywords).",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "نرفق `الجهاز` و`نظام التشغيل` و`إصدار التطبيق` ومعرّف الجلسة تلقائيًا. لا يتم إرسال أي معلومات شخصية." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wir hängen `Gerät`, `OS`, `App-Version` und eine Session-ID automatisch an. Es werden keine persönlichen Daten gesendet." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "We attach `device`, `os`, `app version` and a session id automatically. No personal info is sent." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Adjuntamos `dispositivo`, `os`, `versión de la app` y un identificador de sesión automáticamente. No se envía información personal." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Adjuntamos `dispositivo`, `os`, `versión de la app` y un id de sesión automáticamente. No se envía información personal." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "On joint `appareil`, `os`, `version de l'app` et un identifiant de session automatiquement. Aucune info personnelle n'est envoyée." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "हम स्वचालित रूप से `डिवाइस`, `os`, `ऐप संस्करण` और एक सेशन आईडी अटैच करते हैं। कोई व्यक्तिगत जानकारी नहीं भेजी जाती।" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Alleghiamo `dispositivo`, `os`, `versione app` e un id di sessione automaticamente. Nessuna info personale viene inviata." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "`デバイス`、`os`、`アプリのバージョン` とセッションIDを自動で添付します。個人情報は送信されません。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "`기기`, `os`, `앱 버전`과 세션 ID를 자동으로 첨부합니다. 개인 정보는 보내지 않습니다." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "We voegen automatisch `apparaat`, `os`, `app-versie` en een sessie-id toe. Er wordt geen persoonlijke info verzonden." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Anexamos `dispositivo`, `os`, `versão do app` e um id de sessão automaticamente. Nenhuma info pessoal é enviada." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Мы автоматически прикрепляем `устройство`, `os`, `версию приложения` и id сессии. Личные данные не отправляются." } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "`cihaz`, `os`, `uygulama sürümü` ve bir oturum kimliğini otomatik olarak ekleriz. Kişisel bilgi gönderilmez." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "我们会自动附上`设备`、`os`、`应用版本`和会话 ID。不会发送任何个人信息。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "我們會自動附上`裝置`、`os`、`應用程式版本`和工作階段 ID。不會傳送任何個人資訊。" } }
      }
    },
