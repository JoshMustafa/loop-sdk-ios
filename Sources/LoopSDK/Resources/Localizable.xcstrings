        "hi" : { "stringUnit" : { "state" : "translated", "value" : "टीम को सूचित कर दिया गया है। आपकी रिपोर्ट दूसरों के साथ बोर्ड पर मिलेगी।" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il team è stato avvisato. Trovi il tuo report sulla bacheca insieme agli altri." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "チームに通知しました。あなたのレポートはボードに掲載されています。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "팀에 알림이 갔어요. 보드에서 다른 리포트와 함께 확인하실 수 있어요." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Het team is op de hoogte. Je vindt je rapport op het bord naast die van anderen." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "A equipe foi avisada. Seu relato está no quadro junto com os outros." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Команда получила уведомление. Ваш отчёт уже на доске вместе с другими." } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Ekibe bildirildi. Raporunu panoda diğerleriyle birlikte bulabilirsin." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "团队已收到通知。你的反馈和其他人的一起，已在面板上。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "團隊已收到通知。你的回報已和其他人的一起放在面板上。" } }
